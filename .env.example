# ─── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/jobboard"

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Auth.js ──────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# OAuth providers (add the ones you need)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Inngest ──────────────────────────────────────────────────
INNGEST_EVENT_KEY="local"
INNGEST_SIGNING_KEY=""

# ─── Brevo (email / SMS) ──────────────────────────────────────
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="JobBoard"

# ─── DigitalOcean Spaces ──────────────────────────────────────
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_REGION="nyc3"
DO_SPACES_BUCKET="jobboard-files"
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_CDN_URL="https://jobboard-files.nyc3.cdn.digitaloceanspaces.com"

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
